{
  "name": "recipe-book-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node -r ./scripts/patch-readlink-eisdir.cjs ./node_modules/next/dist/bin/next dev",
    "build": "node -r ./scripts/patch-readlink-eisdir.cjs ./node_modules/next/dist/bin/next build",
    "start": "node -r ./scripts/patch-readlink-eisdir.cjs ./node_modules/next/dist/bin/next start",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "lucide-react": "0.468.0",
    "next": "^14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "autoprefixer": "10.4.20",
    "postcss": "8.4.49",
    "prisma": "5.22.0",
    "tailwindcss": "3.4.16",
    "tsx": "4.19.2",
    "typescript": "5.7.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
